# Enforce LF in the working tree on every OS. The build hashes file bytes, so
# consistent line endings are required for deterministic, cross-platform builds.
* text=auto eol=lf

# Explicit text types (kept LF)
*.md   text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.svg  text eol=lf

# Binary assets (never normalize)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
